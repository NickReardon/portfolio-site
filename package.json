{
  "name": "portfolio-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "astro check",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "resume:build": "node scripts/build-resume.mjs",
    "resume:validate": "node scripts/validate-resume.mjs",
    "clean": "rimraf dist .astro reports .audit-tmp",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:cloudflare": "npm run build && op run --env-file ./.env.1password -- npx --yes wrangler pages deploy dist",
    "audit": "npm run audit:lighthouse && npm run audit:pa11y",
    "audit:lighthouse": "node scripts/audit-pages.mjs lighthouse",
    "audit:pa11y": "node scripts/audit-pages.mjs pa11y",
    "audit:staging": "npm run audit:staging:lighthouse && npm run audit:staging:pa11y",
    "audit:staging:lighthouse": "node scripts/audit-pages.mjs lighthouse https://staging.nick-reardon.com",
    "audit:staging:pa11y": "node scripts/audit-pages.mjs pa11y https://staging.nick-reardon.com",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@lucide/astro": "^1.21.0",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.7",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "lighthouse": "^13.4.0",
    "pa11y": "^9.1.1",
    "prettier": "^3.8.5",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
