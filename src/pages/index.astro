---
import { getCollection } from "astro:content";
import { FileText } from "@lucide/astro";
import BlogCard from "../components/BlogCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site.config";
import { isVisibleContent, sortNewestFirst, sortProjects } from "../utils/content";

const projects = (await getCollection("projects"))
  .filter(isVisibleContent)
  .sort(sortProjects);
const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 3);
const fallbackProjects = featuredProjects.length > 0 ? featuredProjects : projects.slice(0, 3);
const recentPosts = (await getCollection("blog"))
  .filter(isVisibleContent)
  .sort(sortNewestFirst)
  .slice(0, 2);
---

<BaseLayout>
  <section class="section border-b border-stone-200 bg-site-subtle">
    <div class="mx-auto grid max-w-6xl gap-8 px-5 py-12 sm:py-14 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-end">
      <div class="max-w-3xl">
        <p class="eyebrow">Portfolio</p>
        <h1 class="mt-4">
          {site.name}
        </h1>
        <p class="mt-4 text-xl leading-8 text-stone-700">
          {site.role} focused on {site.focus}.
        </p>
        <p class="mt-5 max-w-2xl leading-7 text-stone-650">
          I build reliable gameplay systems with a focus on usability, clear extension
          points, and content workflows that make iteration feel natural for designers.
        </p>
        <div class="hero-actions mt-7 flex flex-wrap gap-3">
          <a class="button-primary" href="/projects/">View Projects</a>
          <a class="button-secondary" href={site.resumeUrl}>
            <FileText size={16} aria-hidden="true" />
            Resume
          </a>
          <a class="button-secondary" href="/contact/">Contact</a>
        </div>
      </div>

      <aside class="border-l-4 border-teal-700 pl-6">
        <p class="eyebrow">Current Focus</p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-stone-700">
          <li>Data-driven Unreal Engine gameplay systems.</li>
          <li>Designer-friendly authoring workflows.</li>
          <li>Readable implementation notes and technical tradeoffs.</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Selected Work</p>
          <h2>Featured projects</h2>
        </div>
        <a class="text-link" href="/projects/">All projects</a>
      </div>

      {
        fallbackProjects.length > 0 ? (
          <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {
              fallbackProjects.map((project, index) => (
                <ProjectCard
                  project={project}
                  headingLevel={3}
                  imageLoading={index < 3 ? "eager" : "lazy"}
                  imageFetchPriority={index === 0 ? "high" : "auto"}
                />
              ))
            }
          </div>
        ) : (
          <p class="empty-state mt-8">More project writeups are coming soon.</p>
        )
      }
    </div>
  </section>

  <section class="section border-t border-stone-200 bg-white">
    <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">About</p>
        <h2>Gameplay systems built around how people actually author content.</h2>
        <p class="mt-4 leading-7 text-stone-650">
          My strongest work comes from self-directed Unreal Engine projects and
          game jams, where I focus on systems that are easy to extend, debug, and
          use under real iteration pressure.
        </p>
        <a class="button-secondary mt-6 inline-flex" href="/about/">Read More</a>
      </div>

      <div>
        <div class="section-heading">
          <div>
            <p class="eyebrow">Devlog</p>
            <h2>Latest posts</h2>
          </div>
          <a class="text-link" href="/blog/">All posts</a>
        </div>
        {
          recentPosts.length > 0 ? (
            <div class="mt-6 grid gap-4">
              {recentPosts.map((post) => <BlogCard post={post} headingLevel={3} />)}
            </div>
          ) : (
            <p class="empty-state mt-6">Devlog posts are coming soon.</p>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
