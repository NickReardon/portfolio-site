---
import { getCollection } from "astro:content";
import ProjectCard from "../../components/ProjectCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { isVisibleContent, sortProjects } from "../../utils/content";

const projects = (await getCollection("projects"))
  .filter(isVisibleContent)
  .sort(sortProjects);
const playableProjects = projects.filter(
  (project) => project.data.projectType === "game",
);
const systemProjects = projects.filter(
  (project) => project.data.projectType !== "game",
);
---

<BaseLayout
  title="Projects"
  description="Portfolio projects and technical case studies."
>
  <section class="section bg-site-subtle">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <p class="eyebrow">Projects</p>
      <h1>Projects and case studies</h1>
      <p class="mt-5 max-w-3xl text-xl leading-8 text-stone-700">
        Playable game-jam projects, Unreal Engine systems work, and notes on
        what I contributed to each project.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="mx-auto max-w-6xl px-5 py-14">
      {
        projects.length > 0 ? (
          <div class="space-y-14">
            {playableProjects.length > 0 && (
              <section aria-labelledby="playable-projects">
                <div class="section-heading">
                  <div>
                    <p class="eyebrow">Playable Work</p>
                    <h2 id="playable-projects">Itch.io projects</h2>
                  </div>
                  <a class="text-link" href="https://thingofnightmare.itch.io/">
                    Itch profile
                  </a>
                </div>
                <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                  {playableProjects.map((project, index) => (
                    <ProjectCard
                      project={project}
                      imageLoading={index < 3 ? "eager" : "lazy"}
                      imageFetchPriority={index === 0 ? "high" : "auto"}
                    />
                  ))}
                </div>
              </section>
            )}

            {systemProjects.length > 0 && (
              <section aria-labelledby="systems-projects">
                <div class="section-heading">
                  <div>
                    <p class="eyebrow">Systems Work</p>
                    <h2 id="systems-projects">Technical case studies</h2>
                  </div>
                </div>
                <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                  {systemProjects.map((project, index) => (
                    <ProjectCard
                      project={project}
                      imageLoading={index < 3 ? "eager" : "lazy"}
                      imageFetchPriority={
                        playableProjects.length === 0 && index === 0
                          ? "high"
                          : "auto"
                      }
                    />
                  ))}
                </div>
              </section>
            )}
          </div>
        ) : (
          <p class="empty-state">More project writeups are coming soon.</p>
        )
      }
    </div>
  </section>
</BaseLayout>
