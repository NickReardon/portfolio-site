---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { Code, ExternalLink, Play } from "@lucide/astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { entrySlug, formatDate, isVisibleContent } from "../../utils/content";

interface Props {
  project: CollectionEntry<"projects">;
}

export async function getStaticPaths() {
  const projects = (await getCollection("projects")).filter(isVisibleContent);

  return projects.map((project) => ({
    params: { slug: entrySlug(project.id) },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const links = [
  { href: project.data.githubUrl, label: "GitHub", Icon: Code },
  { href: project.data.videoUrl, label: "Video", Icon: Play },
  {
    href: project.data.externalUrl,
    label: project.data.externalLabel ?? "Live Site",
    Icon: ExternalLink,
  },
].filter((link) => Boolean(link.href));
const details = [
  { label: "Role", value: project.data.role },
  { label: "Status", value: project.data.status },
  { label: "Engine", value: project.data.engine },
].filter((detail) => Boolean(detail.value));
const timeline = project.data.timeline ?? formatDate(project.data.date);
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  image={project.data.coverImage}
  type="article"
>
  <article>
    <header class="section bg-site-subtle">
      <div
        class="mx-auto grid max-w-6xl gap-10 px-5 py-14 lg:grid-cols-[1fr_380px]"
      >
        <div>
          <p class="eyebrow">{timeline}</p>
          <h1>{project.data.title}</h1>
          <p class="mt-5 text-xl leading-8 text-stone-700">
            {project.data.description}
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
          {
            details.length > 0 && (
              <dl class="mt-8 grid gap-3 sm:grid-cols-3">
                {details.map((detail) => (
                  <div class="project-detail">
                    <dt>{detail.label}</dt>
                    <dd>{detail.value}</dd>
                  </div>
                ))}
              </dl>
            )
          }
          {
            links.length > 0 && (
              <div class="mt-8 flex flex-wrap gap-3">
                {links.map(({ href, label, Icon }) => (
                  <a class="button-secondary" href={href}>
                    <Icon size={16} aria-hidden="true" />
                    {label}
                  </a>
                ))}
              </div>
            )
          }
        </div>

        {
          project.data.coverImage && (
            <Image
              src={project.data.coverImage}
              alt={project.data.coverAlt ?? ""}
              width={760}
              height={475}
              loading="eager"
              fetchpriority="high"
              class="aspect-[16/10] w-full rounded-lg border border-stone-200 object-cover shadow-sm"
            />
          )
        }
      </div>
    </header>

    <div class="section mx-auto max-w-3xl px-5 py-14">
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
