---
import { Download, ExternalLink, FileText, Mail } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import resume from "../data/resume.json";
import { site } from "../site.config";

const linkedInProfile = resume.basics.profiles.find(
  (profile) => profile.network === "LinkedIn",
);
const itchProfile = resume.basics.profiles.find(
  (profile) => profile.network === "Itch.io",
);
const githubProfile = resume.basics.profiles.find(
  (profile) => profile.network === "GitHub",
);

function formatEducation(school: (typeof resume.education)[number]) {
  const parts = [school.studyType, school.area].filter(Boolean);
  return [parts.join(" in "), school.summary].filter(Boolean).join(", ");
}

function formatDate(date: string | undefined) {
  if (!date) {
    return undefined;
  }

  if (date.toLowerCase() === "present") {
    return "Present";
  }

  const [year, month] = date.split("-");
  if (!month) {
    return year;
  }

  return new Intl.DateTimeFormat("en", {
    month: "short",
    year: "numeric",
    timeZone: "UTC",
  }).format(new Date(Date.UTC(Number(year), Number(month) - 1)));
}

function formatDateRange(
  startDate: string | undefined,
  endDate: string | undefined,
) {
  return [formatDate(startDate), formatDate(endDate)]
    .filter(Boolean)
    .join(" - ");
}

function projectMeta(project: (typeof resume.projects)[number]) {
  return [
    formatDateRange(project.startDate, project.endDate),
    ...(project.keywords ?? []),
  ]
    .filter(Boolean)
    .join(" | ");
}

function workMeta(job: (typeof resume.work)[number]) {
  return [job.name, formatDateRange(job.startDate, job.endDate), job.location]
    .filter(Boolean)
    .join(" | ");
}
---

<BaseLayout title="Resume" description={`Resume for ${resume.basics.name}.`}>
  <section class="section border-b border-stone-200 bg-site-subtle">
    <div
      class="mx-auto grid max-w-6xl gap-8 px-5 py-12 sm:py-14 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end"
    >
      <div class="max-w-3xl">
        <p class="eyebrow">Resume</p>
        <h1>{resume.basics.name}</h1>
        <p class="mt-5 text-xl leading-8 text-stone-700">
          {resume.basics.label} focused on {site.focus}.
        </p>
      </div>

      <div class="resume-actions">
        <a class="button-primary" href={`mailto:${resume.basics.email}`}>
          <Mail size={16} aria-hidden="true" />
          Contact
        </a>
        <a
          class="button-secondary"
          href={site.resumePdfUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <ExternalLink size={16} aria-hidden="true" />
          Open PDF
        </a>
        <a class="button-secondary" href={site.resumePdfUrl} download>
          <Download size={16} aria-hidden="true" />
          Download PDF
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div
      class="resume-layout mx-auto grid max-w-6xl gap-8 px-5 py-14 lg:grid-cols-[minmax(0,1fr)_320px]"
    >
      <div class="space-y-8">
        <section class="resume-panel">
          <p class="eyebrow">Profile</p>
          <h2>Gameplay systems with practical authoring workflows.</h2>
          <p>{resume.basics.summary}</p>
        </section>

        {
          resume.work.length > 0 && (
            <section class="resume-panel">
              <p class="eyebrow">Experience</p>
              {resume.work.map((job) => (
                <div class="resume-entry">
                  <div>
                    <h2>{job.position}</h2>
                    <p class="resume-meta">{workMeta(job)}</p>
                  </div>
                  {job.highlights?.length > 0 && (
                    <ul class="resume-highlights">
                      {job.highlights.map((highlight) => (
                        <li>{highlight}</li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </section>
          )
        }

        {
          resume.projects.length > 0 && (
            <section class="resume-panel">
              <p class="eyebrow">Project Experience</p>
              {resume.projects.map((project) => (
                <div class="resume-entry">
                  <div>
                    <h2>{project.name}</h2>
                    <p class="resume-meta">{projectMeta(project)}</p>
                  </div>
                  {project.description && <p>{project.description}</p>}
                  {project.highlights?.length > 0 && (
                    <ul class="resume-highlights">
                      {project.highlights.map((highlight) => (
                        <li>{highlight}</li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </section>
          )
        }

        {
          resume.education.length > 0 && (
            <section class="resume-panel">
              <p class="eyebrow">Education</p>
              {resume.education.map((school, index) => (
                <div class={index > 0 ? "mt-5" : undefined}>
                  <h2>{school.institution}</h2>
                  <p>{formatEducation(school)}</p>
                </div>
              ))}
            </section>
          )
        }
      </div>

      <aside class="resume-sidebar">
        {
          resume.skills.length > 0 && (
            <section>
              <h2>Technical Focus</h2>
              <div class="mt-4 grid gap-4">
                {resume.skills.map((skill) => (
                  <div>
                    <h3>{skill.name}</h3>
                    <div class="mt-2 flex flex-wrap gap-2">
                      {skill.keywords.map((keyword) => (
                        <span class="tag">{keyword}</span>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )
        }

        <section>
          <h2>Links</h2>
          <div class="mt-4 grid gap-3">
            <a class="resume-link" href={`mailto:${resume.basics.email}`}>
              <Mail size={16} aria-hidden="true" />
              Email
            </a>
            {
              githubProfile && (
                <a class="resume-link" href={githubProfile.url}>
                  <ExternalLink size={16} aria-hidden="true" />
                  GitHub
                </a>
              )
            }
            {
              linkedInProfile && (
                <a class="resume-link" href={linkedInProfile.url}>
                  <ExternalLink size={16} aria-hidden="true" />
                  LinkedIn
                </a>
              )
            }
            {
              itchProfile && (
                <a class="resume-link" href={itchProfile.url}>
                  <ExternalLink size={16} aria-hidden="true" />
                  Itch.io
                </a>
              )
            }
            <a
              class="resume-link"
              href={site.resumePdfUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <FileText size={16} aria-hidden="true" />
              PDF
            </a>
          </div>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
