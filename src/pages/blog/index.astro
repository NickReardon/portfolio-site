---
import { getCollection } from "astro:content";
import BlogCard from "../../components/BlogCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { isVisibleContent, sortNewestFirst } from "../../utils/content";

const posts = (await getCollection("blog"))
  .filter(isVisibleContent)
  .sort(sortNewestFirst);
---

<BaseLayout title="Blog" description="Devlog posts and technical notes.">
  <section class="section bg-site-subtle">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <p class="eyebrow">Blog</p>
      <h1>Devlog and notes</h1>
      <p class="mt-5 max-w-3xl text-xl leading-8 text-stone-700">
        Short notes on systems design, implementation tradeoffs, and what I
        learn while building projects.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="mx-auto max-w-4xl px-5 py-14">
      {
        posts.length > 0 ? (
          <div class="grid gap-4">
            {posts.map((post) => (
              <BlogCard post={post} />
            ))}
          </div>
        ) : (
          <p class="empty-state">Devlog posts are coming soon.</p>
        )
      }
    </div>
  </section>
</BaseLayout>
