---
import { navigation, site } from "../site.config";

const currentPath = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header class="site-shell border-b border-stone-200 bg-white/90 backdrop-blur">
  <nav class="mx-auto grid max-w-6xl gap-4 px-5 py-4 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
    <a href="/" class="brand-link group max-w-max">
      <span class="block text-sm font-semibold tracking-[0.18em] text-teal-800 uppercase">
        {site.name}
      </span>
      <span class="block text-sm text-stone-600">{site.role}</span>
    </a>

    <div class="nav-links">
      {
        navigation.map((item) => (
          <a
            href={item.href}
            aria-current={isCurrent(item.href) ? "page" : undefined}
            class:list={[
              "nav-link",
              isCurrent(item.href) && "nav-link-current",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
