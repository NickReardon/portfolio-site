---
import { site } from "../site.config";
---

<footer class="border-t border-stone-200 bg-white">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-8 text-sm text-stone-600 sm:flex-row sm:items-center sm:justify-between">
    <p>&copy; {new Date().getFullYear()} {site.name}. Built with Astro and Cloudflare Pages.</p>
    <div class="flex flex-wrap gap-4">
      <a href={`mailto:${site.email}`} class="footer-link">Email</a>
      {site.githubUrl && <a href={site.githubUrl} class="footer-link">GitHub</a>}
      <a href={site.itchUrl} class="footer-link">Itch.io</a>
      <a href={site.linkedinUrl} class="footer-link">LinkedIn</a>
      <a href={site.resumeUrl} class="footer-link">Resume</a>
    </div>
  </div>
</footer>
