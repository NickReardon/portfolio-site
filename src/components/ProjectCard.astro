---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { entrySlug, formatDate } from "../utils/content";

interface Props {
  project: CollectionEntry<"projects">;
  headingLevel?: 2 | 3;
  imageLoading?: "eager" | "lazy";
  imageFetchPriority?: "high" | "low" | "auto";
}

const {
  project,
  headingLevel = 2,
  imageLoading = "lazy",
  imageFetchPriority,
} = Astro.props;
const { data } = project;
const slug = entrySlug(project.id);
const href = `/projects/${slug}/`;
const playUrl = data.projectType === "game" ? data.externalUrl : undefined;
const Heading = `h${headingLevel}` as "h2" | "h3";
const timeline = data.timeline ?? formatDate(data.date);
---

<article class="card group overflow-hidden">
  <div class="aspect-[16/10] overflow-hidden bg-stone-200">
    {
      data.coverImage ? (
        <Image
          src={data.coverImage}
          alt=""
          width={640}
          height={400}
          loading={imageLoading}
          fetchpriority={imageFetchPriority}
          class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
        />
      ) : (
        <div class="project-placeholder">
          <span>{data.title}</span>
        </div>
      )
    }
  </div>
  <div class="space-y-4 p-5">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="text-sm font-medium text-teal-800">{timeline}</p>
        <Heading class="mt-1 text-xl font-semibold text-stone-950"
          >{data.title}</Heading
        >
      </div>
      {
        data.featured && (
          <span class="rounded-full bg-coral-100 px-3 py-1 text-xs font-semibold text-coral-900">
            Featured
          </span>
        )
      }
    </div>

    {
      (data.role || data.status || data.engine) && (
        <div class="project-card-meta">
          {data.role && <span>{data.role}</span>}
          {data.status && <span>{data.status}</span>}
          {data.engine && <span>{data.engine}</span>}
        </div>
      )
    }

    <p class="text-sm leading-6 text-stone-650">{data.description}</p>

    <div class="flex flex-wrap gap-2">
      {data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <div class="flex flex-wrap gap-x-4 gap-y-2 pt-1 text-sm">
      <a class="text-link" href={href}>Project page</a>
      {
        playUrl && (
          <a
            class="text-link"
            href={playUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            ▶ Play here
          </a>
        )
      }
    </div>
  </div>
</article>
