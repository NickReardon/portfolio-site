---
import type { CollectionEntry } from "astro:content";
import { entrySlug, formatDate } from "../utils/content";

interface Props {
  project: CollectionEntry<"projects">;
  headingLevel?: 2 | 3;
}

const { project, headingLevel = 2 } = Astro.props;
const { data } = project;
const slug = entrySlug(project.id);
const href = `/projects/${slug}/`;
const Heading = `h${headingLevel}` as "h2" | "h3";
---

<article class="card group overflow-hidden">
  <a href={href} class="card-link block">
    <div class="aspect-[16/10] overflow-hidden bg-stone-200">
      {
        data.coverImage ? (
          <img
            src={data.coverImage}
            alt=""
            loading="lazy"
            class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
          />
        ) : (
          <div class="project-placeholder">
            <span>{data.title}</span>
          </div>
        )
      }
    </div>
    <div class="space-y-4 p-5">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="text-sm font-medium text-teal-800">{formatDate(data.date)}</p>
          <Heading class="mt-1 text-xl font-semibold text-stone-950">{data.title}</Heading>
        </div>
        {
          data.featured && (
            <span class="rounded-full bg-coral-100 px-3 py-1 text-xs font-semibold text-coral-900">
              Featured
            </span>
          )
        }
      </div>

      <p class="text-sm leading-6 text-stone-650">{data.description}</p>

      <div class="flex flex-wrap gap-2">
        {data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>
  </a>
</article>
