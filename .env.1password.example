# Copy this file to .env.1password and replace each value with the matching
# 1Password secret reference from your vault/item/field names.
#
# Recommended Wrangler auth: a scoped Cloudflare API token.
CLOUDFLARE_ACCOUNT_ID="op://Private/Cloudflare/account id"
CLOUDFLARE_API_TOKEN="op://Private/Cloudflare/api token"

# Legacy global API key auth requires both values below instead of
# CLOUDFLARE_API_TOKEN.
# CLOUDFLARE_API_KEY="op://Private/Cloudflare/api key"
# CLOUDFLARE_EMAIL="op://Private/Cloudflare/email"
